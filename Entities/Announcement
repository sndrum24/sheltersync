{
  "name": "Announcement",
  "type": "object",
  "properties": {
    "shelter_id": {
      "type": "string",
      "description": "The shelter this announcement belongs to"
    },
    "title": {
      "type": "string",
      "description": "Short title of the announcement"
    },
    "message": {
      "type": "string",
      "description": "Full announcement message"
    },
    "priority": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "urgent"
      ],
      "default": "info",
      "description": "Priority level"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Whether the announcement is currently visible"
    }
  },
  "required": [
    "shelter_id",
    "title",
    "message"
  ]
}